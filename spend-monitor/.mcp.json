{
  "mcpServers": {
    "billing-mcp": {
      "command": "uvx",
      "args": ["awslabs.billing-cost-management-mcp-server@latest"],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_PROFILE": "${user_config.aws_profile}",
        "AWS_REGION": "${user_config.aws_region}"
      }
    }
  }
}
